# Environment Variables — copy to server/.env and fill in values

# ─── Server ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/spconfigurator"
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Secret used to validate token format (32+ random chars).
# Generate with: openssl rand -hex 32
TOKEN_SECRET=change_this_to_a_random_32_char_secret

# Admin panel secret — generate the hash with: cd server && npm run hash-secret -- "<your-secret>"
# Store the bcrypt hash here, NOT the plaintext.
# ADMIN_SECRET_HASH=<bcrypt-hash>
#
# Legacy plaintext fallback (still guarded by timingSafeEqual, but less safe
# if the env file is read by an attacker). Use ADMIN_SECRET_HASH instead.
# Leave both empty to disable the admin panel entirely.
ADMIN_SECRET=change_this_to_a_random_admin_secret

# Optional: restrict admin access to a comma-separated list of trusted IPs.
# When unset, any IP may attempt admin auth (guarded by rate-limit + secret).
# Example: ADMIN_ALLOWED_IPS=203.0.113.10,198.51.100.42
ADMIN_ALLOWED_IPS=

# ─── Client ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
