# ─── SunnyTune environment variables ────────────────────────────────────────
#
# TWO USE CASES for this file:
#
#  1. LOCAL DEV (no Docker)
#     Copy to server/.env and fill in values.
#     The Express server loads it via `dotenv`.
#
#  2. DOCKER (dev OR prod)
#     Copy to .env at the PROJECT ROOT and fill in values.
#     Docker Compose reads the root .env automatically.
#
# Secrets can be generated with: openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev (no Docker): URL of your local PostgreSQL instance.
# Docker: Compose builds this from POSTGRES_USER/PASSWORD below — you don't
#         need DATABASE_URL in the root .env when using Docker.
DATABASE_URL="postgresql://postgres:change_this_password@localhost:5432/sptune"

# Docker-only: credentials used by the postgres container AND injected into
# the server's DATABASE_URL by docker-compose.yml.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_to_a_strong_db_password

# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# The origin the server allows for CORS.
# Local dev:    http://localhost:5173
# Docker dev:   http://localhost:5173
# Production:   https://your-app.vercel.app  (or your custom domain)
CORS_ORIGIN=http://localhost:5173

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Token validation secret — must be 32+ random characters.
# Generate: openssl rand -hex 32
TOKEN_SECRET=change_this_to_a_random_32_char_secret

# ─── Admin panel ──────────────────────────────────────────────────────────────
# RECOMMENDED: store a bcrypt hash so the plaintext never lives in the env.
# Generate:  cd server && npm run hash-secret -- "your-secret-here"
# Then set:  ADMIN_SECRET_HASH=$2b$12$...
# ADMIN_SECRET_HASH=

# Legacy plaintext fallback (still timing-attack-safe, but plaintext is
# visible in the environment). Use ADMIN_SECRET_HASH above for production.
# Leave BOTH empty/unset to disable the admin panel entirely.
ADMIN_SECRET=change_this_to_a_random_admin_secret

# Optional: restrict /admin to a comma-separated list of trusted IPs.
# When unset, any IP can attempt auth (still rate-limited + secret-protected).
# Example: ADMIN_ALLOWED_IPS=203.0.113.10,198.51.100.42
ADMIN_ALLOWED_IPS=

# ─── Client build (Vite) ──────────────────────────────────────────────────────
# The base URL the browser uses to reach the API.
# Local dev:        http://localhost:3001
# Docker dev:       http://localhost:3001
# Docker prod:      /api  (nginx reverse-proxies /api → server container)
# Vercel backend: https://your-backend-project.vercel.app
VITE_API_URL=http://localhost:3001

# ─── Docker production only ───────────────────────────────────────────────────
# Host port to expose the nginx frontend on (default: 80).
CLIENT_PORT=80
