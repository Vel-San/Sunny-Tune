# Environment Variables — copy to server/.env and fill in values

# ─── Server ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:changeme@localhost:5432/spconfigurator"
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Secret used to validate token format (32+ random chars).
# Generate with: openssl rand -hex 32
TOKEN_SECRET=change_this_to_a_random_32_char_secret

# Admin panel secret — used as the password for the /admin route.
# Generate with: openssl rand -hex 24
# Leave empty or unset to disable the admin panel.
ADMIN_SECRET=change_this_to_a_random_admin_secret

# ─── Client ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
